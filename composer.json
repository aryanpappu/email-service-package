{
    "name": "techsolutionstuff/smart-mailer",
    "description": "Laravel package for automatic email provider rotation with rate limiting, failover, and spam protection. Supports 15+ free-tier providers.",
    "type": "library",
    "keywords": ["laravel", "email", "mailer", "smtp", "rotation", "failover", "rate-limiting", "multi-provider"],
    "license": "MIT",
    "authors": [
        {
            "name": "TechSolutionStuff",
            "email": "hello@techsolutionstuff.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/mail": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/cache": "^10.0|^11.0",
        "illuminate/events": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0",
        "symfony/mailer": "^6.0|^7.0",
        "symfony/mime": "^6.0|^7.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "TechSolutionStuff\\SmartMailer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TechSolutionStuff\\SmartMailer\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TechSolutionStuff\\SmartMailer\\SmartMailerServiceProvider"
            ],
            "aliases": {
                "SmartMailer": "TechSolutionStuff\\SmartMailer\\Facades\\SmartMailer"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
